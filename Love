<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>حاسبة الوزن والنظام الغذائي الذكية</title>
    <style>
        :root { --primary: #FFD700; --dark: #1a1a1a; --white: #ffffff; }
        body { background-color: var(--primary); color: var(--dark); font-family: 'Segoe UI', Tahoma, sans-serif; margin: 0; display: flex; flex-direction: column; align-items: center; min-height: 100vh; }
        .container { width: 90%; max-width: 500px; background: var(--white); padding: 25px; margin: 30px 0; border-radius: 20px; box-shadow: 10px 10px 0px var(--dark); border: 3px solid var(--dark); }
        h1 { text-align: center; font-size: 22px; margin-bottom: 20px; }
        .input-group { margin-bottom: 15px; }
        label { display: block; font-weight: bold; margin-bottom: 5px; }
        input { width: 100%; padding: 12px; border: 2px solid var(--dark); border-radius: 10px; box-sizing: border-box; font-size: 16px; outline: none; }
        .btn { width: 100%; background: var(--dark); color: var(--primary); border: none; padding: 15px; border-radius: 10px; font-size: 18px; font-weight: bold; cursor: pointer; margin-top: 10px; transition: 0.3s; }
        .btn:hover { opacity: 0.9; }
        #result-box { margin-top: 20px; display: none; padding: 15px; border-radius: 12px; border: 2px solid var(--dark); background: #fdfdfd; }
        .diet-plan { margin-top: 15px; text-align: right; background: #fff9c4; padding: 15px; border-radius: 8px; font-size: 15px; line-height: 1.6; border-right: 5px solid var(--dark); }
        .diet-plan h3 { margin-top: 0; color: #d32f2f; font-size: 18px; }
        .ad-space { margin: 15px 0; min-height: 90px; background: #eee; display: flex; align-items: center; justify-content: center; border: 1px dashed #999; font-size: 12px; color: #888; }
    </style>
</head>
<body>

<div class="container">
    <h1>حاسبة الوزن والنظام الغذائي 🥗</h1>

    <!-- مساحة إعلان Adsterra العلوي -->
    <div class="ad-space">
        <!-- ضع كود إعلان Adsterra هنا (Banner) -->
        إعلان (بنسل علوي)
    </div>

    <div class="input-group">
        <label>الطول (سم):</label>
        <input type="number" id="height" placeholder="أدخل طولك هنا">
    </div>

    <div class="input-group">
        <label>الوزن (كجم):</label>
        <input type="number" id="weight" placeholder="أدخل وزنك هنا">
    </div>

    <button class="btn" onclick="calculate()">تحليل النتيجة والنظام الغذائي</button>

    <div id="result-box">
        <div id="bmi-res" style="font-size: 20px; font-weight: bold; text-align: center; color: #d32f2f;"></div>
        <div id="diet-info" class="diet-plan"></div>
    </div>

    <!-- مساحة إعلان Adsterra سفلي -->
    <div class="ad-space" style="margin-top: 20px;">
        <!-- ضع كود إعلان Adsterra هنا (Banner) -->
        إعلان (بنسل سفلي)
    </div>
</div>

<script>
    function calculate() {
        const h = document.getElementById('height').value / 100;
        const w = document.getElementById('weight').value;
        const resBox = document.getElementById('result-box');
        const bmiRes = document.getElementById('bmi-res');
        const dietInfo = document.getElementById('diet-info');

        if (h > 0 && w > 0) {
            const bmi = (w / (h * h)).toFixed(1);
            resBox.style.display = "block";
            bmiRes.innerHTML = `مؤشر كتلة جسمك: ${bmi}`;

            let plan = "";
            if (bmi < 18.5) {
                plan = "<h3>نظام زيادة الوزن:</h3><p>أنت تعاني من نحافة، يفضل زيادة السعرات الحرارية.</p><ul><li><b>الأطعمة الموصى بها:</b> المكسرات، الأفوكادو، البطاطس، اللحوم، والبيض.</li><li><b>نصيحة:</b> تناول وجبات خفيفة غنية بالبروتين بين الوجبات الرئيسية.</li></ul>";
            } else if (bmi < 25) {
                plan = "<h3>وزن مثالي ✅:</h3><p>وزنك ممتاز! استمر في الحفاظ على هذا التوازن.</p><ul><li><b>الأطعمة الموصى بها:</b> الفواكه، الخضروات، والأسماك.</li><li><b>نصيحة:</b> مارس الرياضة لمدة 30 دقيقة يومياً للحفاظ على لياقتك.</li></ul>";
            } else {
                plan = "<h3>نظام تنزيل الوزن:</h3><p>لديك زيادة في الوزن، ننصحك باتباع حمية قليلة السعرات.</p><ul><li><b>الأطعمة الموصى بها:</b> الخضروات الورقية، الشوفان، الزبادي، والبروتينات المشوية.</li><li><b>نصيحة:</b> اشرب الكثير من الماء قبل الوجبات وتجنب السكريات والمشروبات الغازية.</li></ul>";
            }
            dietInfo.innerHTML = plan;
            
            // تمرير الشاشة للنتيجة تلقائياً
            resBox.scrollIntoView({ behavior: 'smooth' });
        } else {
            alert("يرجى إدخال أرقام صحيحة للطول والوزن");
        }
    }
</script>

</body>
</html>
