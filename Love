<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>حاسبة الوزن والنظام الغذائي</title>
    <style>
        :root { --primary: #FFD700; --dark: #1a1a1a; --white: #ffffff; }
        body { background-color: var(--primary); color: var(--dark); font-family: 'Segoe UI', Tahoma, sans-serif; margin: 0; display: flex; flex-direction: column; align-items: center; min-height: 100vh; }
        .container { width: 90%; max-width: 500px; background: var(--white); padding: 25px; margin: 30px 0; border-radius: 20px; box-shadow: 10px 10px 0px var(--dark); border: 3px solid var(--dark); }
        h1 { text-align: center; font-size: 22px; }
        .input-group { margin-bottom: 15px; }
        label { display: block; font-weight: bold; margin-bottom: 5px; }
        input { width: 100%; padding: 12px; border: 2px solid var(--dark); border-radius: 10px; box-sizing: border-box; }
        .btn { width: 100%; background: var(--dark); color: var(--primary); border: none; padding: 15px; border-radius: 10px; font-size: 18px; font-weight: bold; cursor: pointer; margin-top: 10px; }
        #result-box { margin-top: 20px; display: none; padding: 15px; border-radius: 12px; border: 2px solid var(--dark); background: #fdfdfd; }
        .diet-plan { margin-top: 15px; text-align: right; background: #fff9c4; padding: 10px; border-radius: 8px; font-size: 14px; }
        .diet-plan h3 { margin-top: 0; color: #d32f2f; font-size: 16px; }
        .ad-space { margin: 15px 0; min-height: 90px; background: #eee; display: flex; align-items: center; justify-content: center; border: 1px dashed #999; }
    </style>
</head>
<body>

<div class="container">
    <h1>حاسبة الوزن والنظام الغذائي 🥗</h1>

    <div class="ad-space">
        <!-- كود إعلان Adsterra هنا -->
        إعلان علوي
    </div>

    <div class="input-group">
        <label>الطول (سم):</label>
        <input type="number" id="height" placeholder="مثال: 170">
    </div>

    <div class="input-group">
        <label>الوزن (كجم):</label>
        <input type="number" id="weight" placeholder="مثال: 70">
    </div>

    <button class="btn" onclick="calculate()">تحليل الوزن والنظام الغذائي</button>

    <div id="result-box">
        <div id="bmi-res" style="font-size: 20px; font-weight: bold; text-align: center;"></div>
        <div id="diet-info" class="diet-plan"></div>
    </div>

    <div class="ad-space">
        <!-- كود إعلان Adsterra هنا -->
        إعلان سفلي
    </div>
</div>

<script>
    function calculate() {
        const h = document.getElementById('height').value / 100;
        const w = document.getElementById('weight').value;
        const resBox = document.getElementById('result-box');
        const bmiRes = document.getElementById('bmi-res');
        const dietInfo = document.getElementById('diet-info');

        if (h > 0 && w > 0) {
            const bmi = (w / (h * h)).toFixed(1);
            resBox.style.display = "block";
            bmiRes.innerHTML = `مؤشر الكتلة: ${bmi}`;

            let plan = "";
            if (bmi < 18.5) {
                plan = "<h3>نظام زيادة الوزن:</h3><ul><li><b>ماذا تأكل:</b> المكسرات، الأفوكادو، زيت الزيتون، اللحوم الحمراء، والنشويات (بطاطس، أرز).</li><li><b>نصيحة:</b> تناول 5 وجبات صغيرة يومياً بدلاً من 3 كبيرة.</li></ul>";
            } else if (bmi < 25) {
                plan = "<h3>نظام المحافظة على الوزن:</h3><ul><li><b>ماذا تأكل:</b> الخضروات الورقية، الفواكه، البروتينات الخالية من الدهون (صدر دجاج، سمك).</li><li><b>نصيحة:</b> استمر على توازن الكربوهيدرات والبروتين والدهون الصحية.</li></ul>";
            } else {
                plan = "<h3>نظام تنزيل الوزن:</h3><ul><li><b>ماذا تأكل:</b> البيض المسلوق، الشوفان، السلطات الخضراء، التفاح، والزبادي قليل الدسم.</li><li><b>نصيحة:</b> اشرب كوبين من الماء قبل كل وجبة وقلل من الخبز الأبيض والسكريات.</li></ul>";
            }
            dietInfo.innerHTML = plan;
        } else {
            alert("أدخل الطول والوزن بشكل صحيح");
        }
    }
</script>

</body>
</html>
